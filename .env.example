# ============================================================
# Supabase Auth (Client-side)
# Used for: Supabase client-side authentication
# These are public variables exposed to the browser
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================
# Supabase Storage (Server-side)
# Used for: Server-side file upload/delete to Supabase Storage
# These are private and should NEVER be exposed to the client
# ============================================================
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_MEDIA=media
SUPABASE_STORAGE_BUCKET_VIDEO=video

# ============================================================
# Supabase PostgreSQL (Database)
# Used for: Drizzle ORM direct connection to PostgreSQL
# Only one database connection is used for the entire app
# ============================================================
DATABASE_URL=

# ============================================================
# Mapbox (Client-side)
# Used for: Maps and geolocation features in the frontend
# ============================================================
NEXT_PUBLIC_MAPBOX_TOKEN=
